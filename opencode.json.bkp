{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nexus": {
      "command": [
        "npx",
        "--yes",
        "@gwdn/nexus-mcp@latest"
      ],
      "environment": {
        "NEXUS_API_URL": "https://nexus.gatewarden.eu",
        "NEXUS_PRIVATE_TOKEN": "nxs_pat_J6AocMVNWnCBm_ssNL5Zu4BOtvraUfDF7jjaTDFQdSo"
      },
      "type": "local"
    },
    "task-master-ai": {
      "command": [
        "npx",
        "-y",
        "task-master-ai@latest"
      ],
      "environment": {
        "ANTHROPIC_API_KEY": "{env:ANTHROPIC_API_KEY}",
        "GOOGLE_API_KEY": "{env:GOOGLE_API_KEY}",
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}",
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
      },
      "type": "local"
    },
    "headroom": {
      "command": [
        "headroom",
        "mcp",
        "serve"
      ],
      "type": "local"
    }
  }
}
